# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Gemini API — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API — get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Analytics 4 — get from https://analytics.google.com
# Format: G-XXXXXXXXXX
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudflare Web Analytics — get from Cloudflare Dashboard > Analytics > Web Analytics
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN=your_token_here

# Cloudflare bindings (KV + Browser Rendering) are configured in wrangler.toml.
# No extra env vars needed for bindings in local dev — use `pnpm dev` with wrangler.
